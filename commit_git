#!/usr/bin/env node

import { mkdtempSync, rmSync, writeFileSync } from "node:fs";
import { tmpdir } from "node:os";
import { join, resolve } from "node:path";
import { parseArgs } from "./lib/args.mjs";
import { collectGitDiff, createCommit, getCurrentBranch, getRepoRoot, hasAnyChanges, hasStagedChanges, pushBranch, stageAllChanges } from "./lib/git.mjs";
import { buildCommitMessage, normalizeBody, normalizeSummary } from "./lib/message.mjs";
import { buildPrompt, buildSchema } from "./lib/prompt.mjs";
import { resolveProvider } from "./lib/providers/index.mjs";
import { VALID_PREFIXES } from "./lib/constants.mjs";
import { fail, readStdin } from "./lib/utils.mjs";

async function main() {
  const options = parseArgs(process.argv.slice(2));
  options.repo = resolve(options.repo);

  const llm = resolveProvider(options.provider);

  if (options.action === "print" && options.push) {
    fail("--push cannot be used together with --print");
  }

  const stdinDiff = process.stdin.isTTY ? "" : await readStdin();
  const usingStdin = stdinDiff.trim().length > 0;

  let diffPayload;
  let workingDirectory = options.repo;
  let branch = "stdin-only";

  if (usingStdin) {
    options.action = "print";
    diffPayload = {
      stat: "",
      patch: stdinDiff.trim(),
      source: "stdin diff",
    };
  } else {
    const repoRoot = getRepoRoot(options.repo);
    workingDirectory = repoRoot;
    branch = getCurrentBranch(repoRoot);

    if (options.action === "commit") {
      if (options.mode === "cached") {
        if (!hasStagedChanges(repoRoot)) {
          fail("No staged changes found. Stage changes first or run commit_git without --cached.");
        }
      } else {
        if (!hasAnyChanges(repoRoot)) {
          fail("No changes found to commit.");
        }
        stageAllChanges(repoRoot);
        options.mode = "cached";
      }
    }

    diffPayload = collectGitDiff(repoRoot, options.mode);
  }

  if (!diffPayload.patch) {
    fail("No diff found. Stage changes, use --unstaged/--all, or pipe a diff into stdin.");
  }

  const prompt = buildPrompt({
    ...diffPayload,
    forcedPrefix: options.forcedPrefix,
  });

  const tempDir = mkdtempSync(join(tmpdir(), "commit-git-llm-"));
  const schemaPath = join(tempDir, "schema.json");
  const outputPath = join(tempDir, "result.json");
  const schema = buildSchema(options.forcedPrefix);

  writeFileSync(schemaPath, JSON.stringify(schema, null, 2));

  let parsed;
  try {
    parsed =
      llm.provider === "codex"
        ? llm.generate(llm.binary, workingDirectory, prompt, schemaPath, outputPath)
        : llm.generate(llm.binary, workingDirectory, prompt, schema);
  } catch (error) {
    fail(error instanceof Error ? error.message : String(error));
  } finally {
    rmSync(tempDir, { recursive: true, force: true });
  }

  const prefix = parsed.prefix;
  if (!VALID_PREFIXES.has(prefix)) {
    fail(`LLM returned an invalid prefix: ${prefix}`);
  }

  const summary = normalizeSummary(prefix, String(parsed.summary || ""));
  const body = normalizeBody(parsed.body);
  const message = buildCommitMessage(prefix, summary, body);

  if (options.action === "print") {
    console.log(message);
    return;
  }

  createCommit(workingDirectory, message);

  if (options.push) {
    pushBranch(workingDirectory, branch);
  }
}

main().catch((error) => {
  fail(error instanceof Error ? error.message : String(error));
});
